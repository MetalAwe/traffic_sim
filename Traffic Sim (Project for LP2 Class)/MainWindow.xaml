<Window x:Class="Traffic_Sim__Project_for_LP2_Class_.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Traffic_Sim__Project_for_LP2_Class_"
        mc:Ignorable="d"
        Title="Traffic Simulator" Height="450" Width="800">
    <Grid Background="#2C3E50"> <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250" />
        </Grid.ColumnDefinitions>
        <Canvas x:Name="TrafficCanvas" Grid.Column="0" Background="#34495E">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="10">

            </StackPanel>
        </Canvas>
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Grid.Column="1" Background="#ECF0F1" Margin="0,10,10,10">
                <Border CornerRadius="5" Background="#3498DB" Margin="10">
                    <TextBlock Text="TRAFFIC CONTROL" Foreground="White" HorizontalAlignment="Center" FontWeight="Bold" Padding="10"/>
                </Border>
                <GroupBox Header="Live Statistics" Margin="10">
                    <StackPanel>
                        <Label Content="Active Vehicles"/>
                        <TextBox x:Name="TxtVehicleCount" Text="0" FontSize="20" Margin="5"/>
                        <Label Content="Current Light"/>
                        <Ellipse x:Name="LightIndicator" Width="20" Height="20" Fill="Green" HorizontalAlignment="Left" Margin="5"/>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Simulation Settings" Margin="10">
                    <StackPanel>
                        <Label Content="Simulation Speed:"/>
                        <Slider x:Name="SldSimSpeed" Minimum="1" Maximum="10" Value="5" TickFrequency="1" IsSnapToTickEnabled="True"/>

                        <Button Content="Change Light" Width="100" Margin="5" Click="ChangeLight" Height="20"/>
                        <Button Content="Add Car" Width="100" Margin="5" Click="AddCar" Height="20"/>
                        <Button Content="Add Ambulance" Width="100" Margin="5" Click="AddAmbulance" Height="20"/>
                        <Button Content="Add Bus" Width="100" Margin="5" Click="AddBus" Height="20"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
