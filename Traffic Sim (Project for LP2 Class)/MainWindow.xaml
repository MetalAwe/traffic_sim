<Window x:Class="Traffic_Sim__Project_for_LP2_Class_.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Traffic_Sim__Project_for_LP2_Class_"
        mc:Ignorable="d"
        Title="Traffic Simulator" Height="450" Width="800">
    <Grid>
        <Canvas x:Name="TrafficCanvas" Background="LightGray">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="10">
                <Button Content="Change Light" Width="100" Margin="5" Click="ChangeLight" Height="30"/>
                <Button Content="Add Car" Width="100" Margin="5" Click="AddCar" Height="30"/>
                <Button Content="Add Ambulance" Width="100" Margin="5" Click="AddAmbulance" Height="30"/>
                <Button Content="Add Bus" Width="100" Margin="5" Click="AddBus" Height="30"/>
            </StackPanel>
        </Canvas>
    </Grid>
</Window>
